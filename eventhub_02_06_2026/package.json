{
  "name": "eventhub-webinar",
  "version": "1.0.0",
  "description": "EventHub Serverless - Plataforma de gestão de eventos e inscrições com AWS SAM",
  "scripts": {
    "build": "sam build",
    "test": "jest --coverage",
    "test:unit": "jest --testPathPattern=tests/unit",
    "test:property": "jest --testPathPattern=tests/property",
    "lint": "tsc --noEmit",
    "deploy": "sam deploy",
    "validate": "sam validate",
    "seed:events": "npx tsx scripts/seed-events.ts"
  },
  "keywords": [
    "aws",
    "sam",
    "serverless",
    "lambda",
    "typescript"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@aws-lambda-powertools/logger": "^2.33.1",
    "@aws-lambda-powertools/metrics": "^2.33.1",
    "@aws-lambda-powertools/tracer": "^2.33.1",
    "@types/aws-lambda": "^8.10.145",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.17.0",
    "@types/pg": "^8.20.0",
    "aws-sdk-client-mock": "^4.1.0",
    "esbuild": "^0.24.0",
    "fast-check": "^3.22.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "@aws-sdk/client-cloudformation": "^3.1057.0",
    "@aws-sdk/client-dynamodb": "^3.1057.0",
    "@aws-sdk/client-rds": "^3.1057.0",
    "@aws-sdk/client-rds-data": "^3.1057.0",
    "@aws-sdk/client-s3": "^3.1057.0",
    "@aws-sdk/client-secrets-manager": "^3.1057.0",
    "@aws-sdk/credential-providers": "^3.1057.0",
    "@aws-sdk/lib-dynamodb": "^3.1057.0",
    "@aws-sdk/s3-request-presigner": "^3.1057.0",
    "pg": "^8.21.0"
  }
}
